{
	"name": "playlist-party.com",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "ADAPTER=node vite dev --port 3103 --host",
		"build": "ADAPTER=node vite build",
		"preview": "ADAPTER=node vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "bun run format && bun run lint && bun run check:types",
		"check:types": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "eslint .",
		"test": "vitest run && playwright test",
		"test:unit": "vitest run",
		"test:e2e": "playwright test",
		"deploy": "./scripts/deploy.sh",
		"db:sync": "./scripts/sync-db.sh",
		"db:backup": "./scripts/backup.sh",
		"creation-log": "bun scripts/build-creation-log.ts",
		"ncu": "ncu",
		"ncu:apply": "ncu -u && bun install"
	},
	"devDependencies": {
		"@eslint/js": "10.0.1",
		"@playwright/test": "1.58.2",
		"@sveltejs/adapter-auto": "7.0.1",
		"@sveltejs/adapter-cloudflare": "7.2.8",
		"@sveltejs/adapter-node": "5.5.4",
		"@sveltejs/kit": "2.55.0",
		"@sveltejs/vite-plugin-svelte": "7.0.0",
		"@tailwindcss/vite": "4.2.2",
		"@types/better-sqlite3": "7.6.13",
		"better-sqlite3": "12.8.0",
		"drizzle-kit": "0.31.10",
		"eslint": "10.1.0",
		"eslint-plugin-svelte": "3.16.0",
		"globals": "17.4.0",
		"npm-check-updates": "19.6.5",
		"prettier": "3.8.1",
		"prettier-plugin-svelte": "3.5.1",
		"svelte": "5.54.1",
		"svelte-check": "4.4.5",
		"tailwindcss": "4.2.2",
		"typescript": "5.9.3",
		"typescript-eslint": "8.57.1",
		"vite": "8.0.1",
		"vitest": "4.1.0",
		"wrangler": "4.76.0"
	},
	"dependencies": {
		"drizzle-orm": "0.45.1",
		"nanoid": "5.1.7"
	}
}
